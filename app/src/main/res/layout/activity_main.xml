<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="İSUTS"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#004D40"
            android:textAlignment="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="İlaç - Semptom Uyuşmazlık Tespit Sistemi"
            android:textSize="14sp"
            android:textColor="#455A64"
            android:textAlignment="center"
            android:layout_marginBottom="18dp" />

        <Button
            android:id="@+id/btnKamera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#004D40"
            android:textColor="#FFFFFF"
            android:text="Kamerayı Aç ve İlaç Tarat" />

        <ImageView
            android:id="@+id/imgOnizleme"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="12dp"
            android:background="#CFD8DC"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/txtSonuc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Taranan ilaç bekleniyor..."
            android:textStyle="bold"
            android:textColor="#263238"
            android:padding="12dp"
            android:background="#FFFFFF" />

        <Button
            android:id="@+id/btnAnaliz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="#00695C"
            android:textColor="#FFFFFF"
            android:text="Uyuşmazlıkları Analiz Et" />

        <Button
            android:id="@+id/btnManuelGiris"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:text="Manuel İlaç / ICD-10 Girişi" />

        <Button
            android:id="@+id/btnPdfRapor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:backgroundTint="#6A1B9A"
            android:textColor="#FFFFFF"
            android:text="PDF Rapor Oluştur" />

        <Button
            android:id="@+id/btnTemizle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:backgroundTint="#C62828"
            android:textColor="#FFFFFF"
            android:text="İlaç / Hastalık Listesini Temizle" />

        <LinearLayout
            android:id="@+id/layoutRisk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginTop="14dp"
            android:background="#FFFFFF"
            android:elevation="3dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtRiskBaslik"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:padding="8dp"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/txtRiskAciklama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#000000"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>